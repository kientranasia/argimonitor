# Docker publish port (host:container => FRONTEND_PORT:80)
FRONTEND_PORT=8085

# Frontend build-time API base. Keep /api when using nginx reverse-proxy.
VITE_API_BASE=/api

# Crawler schedule
CRAWLER_INTERVAL_SECONDS=1800
CRAWLER_INITIAL_BACKFILL_DAYS=30

# Backend submit API basic auth
SUBMIT_BASIC_USER=submit_admin
SUBMIT_BASIC_PASSWORD=change_me_submit

# LLM keys for dashboard AI alerts (optional; at least one if you want AI-generated pills)
GEMINI_API_KEY=

# OpenAI Chat Completions (optional fallback when Gemini is empty). Create key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
